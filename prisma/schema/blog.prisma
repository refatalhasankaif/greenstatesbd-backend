model Blog {
    id String @id @default(uuid())

    title   String
    content String

    isBlocked Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    authorId String
    author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)

    @@index([authorId])
    reports Report[]
}