model Gallery {
    id String @id @default(uuid())

    imageUrl String
    publicId String

    title String

    likesCount Int     @default(0)
    isBlocked  Boolean @default(false)

    createdAt DateTime @default(now())

    userId  String
    user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    likes   GalleryLike[]
    reports Report[]

    @@index([userId])
    @@index([likesCount])
}
